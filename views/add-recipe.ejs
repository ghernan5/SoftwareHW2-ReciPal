<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>ReciPal | New Recipe</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <a href="/">Home</a>
        <a href="/recipes">Recipes</a>
        <a href="/add-recipe">Add New</a>
    </nav>
    <div class="container">
        <form action="/add-recipe" method="POST" class="card" id="recipeForm">
            <h1>Add a New Recipe</h1>     
            <label for="title">Recipe Title:</label><br>
            <input type="text" id="title" name="title" required style="width:80%; padding:8px; margin-bottom:15px;">
            <br><label for="protein_type">Main Protein:</label><br>
            <select name="protein_type" id="protein_type" required style="padding:8px; margin-bottom:15px;">
                <option value="Chicken">Chicken</option>
                <option value="Beef">Beef</option>
                <option value="Tofu">Tofu</option>
                <option value="Grains">Grains</option>
            </select>
            <br><label>Select Ingredients (Hold Ctrl/Cmd to select multiple):</label><br>
            <select name="ingredient_ids" multiple required style="width:80%; height:120px; padding:8px; margin-bottom:15px;">
                <% ingredients.forEach(ing => { %>
                    <option value="<%= ing.id %>"><%= ing.name %></option>
                <% }) %>
            </select>
            <br><label for="instructions">Instructions:</label><br>
            <textarea name="instructions" id="instructions" rows="5" required style="width:80%; padding:8px;"></textarea>
            <br><br>
            <button type="submit" class="view-link" style="border:none; cursor:pointer;">Save Recipe</button>
        </form>
    </div>

    <script src="/js/script.js"></script>
</body>
</html>
